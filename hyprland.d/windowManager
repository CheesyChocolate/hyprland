# Hyprland general configuration file

general {
	# size of the border around windows
	border_size = 3
	# gaps between windows
	gaps_in = 5
	# gaps between windows and the screen edge
	gaps_out = 10
	# window colors
	col.inactive_border = rgb(444444)
	col.active_border = rgb(770000)
	# the dynamic tiling, mode
	layout = master
}

misc {
	disable_hyprland_logo = true
	disable_splash_rendering = true
	background_color = rgb(222222)
	# TODO: disable autoreload
	# disable_autoreload = true
	# If DPMS is set to off, wake up the monitors if the mouse moves or a key is pressed.
	mouse_move_enables_dpms = true
	key_press_enables_dpms = true
	# Enable window swallowing
	enable_swallow = true
	swallow_regex = ^(kitty)$
	# Enable session lock restore
	# allow_session_lock_restore = true
	# vraiable refresh rete
	vrr = 1
}

decoration {
	active_opacity = 1.0
	inactive_opacity = 1.0

	shadow {
		enabled = false
		offset = 2 2
		render_power = 2
		color = rgb(000000)
	}

	blur {
		enabled = false
		size = 3
		passes = 3
		ignore_opacity = true
		xray = true
	}

	blurls = lockscreen
}

animations {
	enabled = false
}

dwindle {
	pseudotile = yes # master switch for pseudotiling. Enabling is bound to mainMod + P in the keybinds section below
	preserve_split = yes # you probably want this
}

master {
	new_on_top = true
	smart_resizing = false
}
