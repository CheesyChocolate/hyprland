# vim: ft=config

windowrule = 	float, 				initialclass:confirm
windowrule = 	float, 				initialclass:dialog
windowrule = 	float, 				initialclass:download
windowrule = 	float, 				initialclass:notification
windowrule = 	float, 				initialclass:error
windowrule = 	float, 				initialclass:splash
windowrule = 	float, 				initialclass:confirmreset
windowrule = 	float, 				initialtitle:Open File
windowrule = 	float, 				initialtitle:branchdialog
windowrule = 	float,				initialtitle:^(Picture-in-Picture)$

windowrule = 	idleinhibit focus,		initialclass:mpv
windowrule = 	idleinhibit fullscreen,		initialclass:librewolf

# force the window to be centered, normally it opens on the pointers position
windowrule = 	center,				initialtitle:File Upload
